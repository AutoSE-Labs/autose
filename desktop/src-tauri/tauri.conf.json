{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoSE",
  "version": "0.1.1",
  "identifier": "dev.autose.desktop",
  "build": {
    "beforeDevCommand": "node scripts/stage-backend.mjs && npm run ui:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "node scripts/stage-backend.mjs && npm run ui:build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "backend": "backend"
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "AutoSE",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}